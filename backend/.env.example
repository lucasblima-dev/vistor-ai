# Banco de Dados (PostgreSQL + PostGIS)
# Para execução local (fora do Docker): usar localhost
# Para execução dentro do Docker: usar o nome do serviço 'db'
DATABASE_URL=postgresql+asyncpg://postgres:senha_db@localhost:5432/vistor_ai

# MinIO (S3-compatible storage)
MINIO_USER="admin"
MINIO_PASSWORD="senha_minio"
MINIO_ENDPOINT="localhost:9000"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="gere_um_segredo_seguro"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# HuggingFace (IA)
HF_API_KEY="sua_chave_hf"
HF_MODEL_ID="google/vit-base-patch16-224"
HF_TIMEOUT_SECONDS=10
HF_CONFIDENCE_THRESHOLD=0.55

# FastAPI Settings
ENVIRONMENT="development"
ALLOWED_ORIGINS='["http://localhost:3000"]'
