# URL base da API (backend rodando via Docker)
# Emulador Android: use 10.0.2.2 em vez de localhost
# Dispositivo físico: use o IP da sua máquina na rede local (ex: 192.168.1.10)
API_BASE_URL=http://10.0.2.2:8000

# Sentry — monitoramento de erros em produção (opcional)
SENTRY_DSN=

# Flavor do ambiente
ENVIRONMENT=development