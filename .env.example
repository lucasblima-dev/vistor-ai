# Banco de Dados (PostgreSQL + PostGIS)
DB_PASSWORD="mude_essa_senha_123"
# No Docker Compose, o host do banco é 'db'
DATABASE_URL=postgresql+asyncpg://postgres:mude_essa_senha_123@db:5432/vistor_ai

# MinIO (S3-compatible storage)
MINIO_USER="admin"
MINIO_PASSWORD="mude_essa_senha_minio"
# No Docker Compose, o host do MinIO é 'minio'
MINIO_ENDPOINT="http://minio:9000"

# Redis
# No Docker Compose, o host do Redis é 'redis'
REDIS_URL="redis://redis:6379"

# JWT Auth
JWT_SECRET="gere_um_segredo_seguro_com_openssl_rand_hex_32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# HuggingFace (IA)
HF_API_KEY="sua_chave_hf_aqui"
HF_MODEL_ID="google/vit-base-patch16-224"
HF_TIMEOUT_SECONDS=10
HF_CONFIDENCE_THRESHOLD=0.55

# FastAPI Settings
ENVIRONMENT="development"
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:8080"]'
API_HOST="0.0.0.0"
API_PORT=8000